@startjson
{
  "Caso de uso": "Generar Reporte de Casos",
  "Id": "CU-M2-04",
  "Breve descripción": "Permite al administrador o al gerente/socio generar un reporte con indicadores de casos activos, tasa de cumplimiento y carga de abogados.",
  "Actores primarios": "Administrador, Gerente / Socio",
  "Actores secundarios": "ReporteController, ReporteServiceImpl, CasoServiceImpl, ReporteRepository",
  "Precondiciones": [
    "El usuario ha iniciado sesión con un rol autorizado para consultar reportes."
  ],
  "Flujo principal": {
    "1": "El usuario selecciona el tipo de reporte y el rango de fechas.",
