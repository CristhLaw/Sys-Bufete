    "4": "ReporteServiceImpl consolida los indicadores mediante ReporteRepository.",
    "5": "El sistema presenta el reporte solicitado.",
    "6": "El usuario puede exportar el reporte en PDF o Excel (CU-M2-05)."
  },
  "Postcondiciones": [
    "El reporte queda disponible para su visualización o descarga.",
    "ReporteServiceImpl no modifica datos de negocio de otros módulos (solo lectura)."
  ],
  "Flujos alternativos": {
    "A1: Sin datos en el rango seleccionado": "El sistema informa que no existen registros para el período consultado."
  }
}
@endjson
