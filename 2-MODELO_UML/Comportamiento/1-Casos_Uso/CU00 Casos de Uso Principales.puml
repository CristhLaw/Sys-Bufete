@startuml
left to right direction
skinparam packageStyle rectangle

title CU00 - Casos de Uso Principales del Sistema Jurídico

actor "Cliente" as Cliente
actor "Secretaria" as Secretaria
actor "Abogado" as Abogado
actor "Administrador" as Administrador
actor "Gerente / Socio" as Gerente

rectangle "Módulo de Casos" {
    usecase "Solicitar consulta legal" as UC_SolicitarConsulta
    usecase "Registrar caso" as UC_RegistrarCaso
    usecase "Asignar abogado" as UC_AsignarAbogado
    usecase "Actualizar estado del caso" as UC_ActualizarEstado
    usecase "Cerrar caso" as UC_CerrarCaso
    usecase "Generar reporte de casos" as UC_GenerarReporte
    usecase "Exportar reporte" as UC_ExportarReporte
}

rectangle "Módulo de Documentos" {
    usecase "Subir documento" as UC_SubirDocumento
    usecase "Consultar documento" as UC_ConsultarDocumento
    usecase "Descargar documento" as UC_DescargarDocumento
}

rectangle "Módulo de Comunicación" {
    usecase "Enviar mensaje" as UC_EnviarMensaje
    usecase "Realizar videollamada" as UC_Videollamada
}

UC_SolicitarConsulta .> UC_RegistrarCaso : <<include>>
UC_RegistrarCaso .> UC_AsignarAbogado : <<include>>
UC_ActualizarEstado .> UC_CerrarCaso : <<extend>>
UC_GenerarReporte .> UC_ExportarReporte : <<include>>
UC_SubirDocumento .> UC_ConsultarDocumento : <<include>>
UC_EnviarMensaje .> UC_Videollamada : <<extend>>

Cliente --> UC_SolicitarConsulta
Cliente --> UC_SubirDocumento
Cliente --> UC_ConsultarDocumento
Cliente --> UC_DescargarDocumento
Cliente --> UC_EnviarMensaje
Cliente --> UC_Videollamada

Secretaria --> UC_RegistrarCaso
Secretaria --> UC_AsignarAbogado
Secretaria --> UC_GenerarReporte

Abogado --> UC_ActualizarEstado
Abogado --> UC_CerrarCaso
Abogado --> UC_SubirDocumento
Abogado --> UC_ConsultarDocumento
Abogado --> UC_DescargarDocumento
Abogado --> UC_EnviarMensaje

Administrador --> UC_AsignarAbogado
Administrador --> UC_GenerarReporte
Administrador --> UC_ExportarReporte

Gerente --> UC_GenerarReporte
Gerente --> UC_ExportarReporte

@enduml
