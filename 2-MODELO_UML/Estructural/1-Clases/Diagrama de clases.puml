@startuml IURIS_MVP_v1

skinparam dpi 96
skinparam nodesep 30
skinparam ranksep 50

skinparam defaultFontName Helvetica
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam padding 2
skinparam roundcorner 6
skinparam ArrowThickness 1.6
skinparam ArrowColor #1B1F23
skinparam ArrowFontColor #1B1F23
skinparam ArrowFontSize 10

skinparam class {
  BorderColor #37474F
  BorderThickness 1
  FontColor #1B1F23
  FontSize 11
  FontStyle bold
  AttributeFontColor #37474F
  AttributeFontSize 10
}

skinparam class<<Usuarios>> {
  BackgroundColor #E8F1FB
  BorderColor #1E5A96
}

skinparam class<<Legal>> {
  BackgroundColor #EAF6EC
  BorderColor #2E7D4F
}

skinparam class<<Auditoria>> {
  BackgroundColor #FDEBEE
  BorderColor #A32638
}

skinparam enum {
  BorderColor #607D8B
  BackgroundColor #F5F7F8
}

title Sistema IURIS - Diagrama de Clases (MVP)

package "Enumeraciones" {
  enum RolUsuario {
    CLIENTE
    ABOGADO
    ADMINISTRADOR
  }

  enum EstadoCaso {
    ACTIVO
    EN_AUDIENCIA
    EN_ESPERA
    CERRADO
    ARCHIVADO
  }

  enum TipoActuacion {
    AUDIENCIA
    ESCRITO
    NOTIFICACION
    DILIGENCIA
    RESOLUCION
    OTRO
  }

  enum EstadoCita {
    PROGRAMADA
    CONFIRMADA
    REALIZADA
    CANCELADA
  }

  enum AccionAuditoria {
    CREACION
    MODIFICACION
    ELIMINACION
    CONSULTA
    LOGIN
    LOGIN_FALLIDO
  }
}

package "Usuarios y Seguridad" {

  abstract class Usuario <<Usuarios>> {
    - id : Long
    - nombres : String
    - apellidos : String
    - email : String
    - passwordHash : String
    - telefono : String
    - rol : RolUsuario
    - activo : Boolean
    - emailVerificado : Boolean
    - fechaCreacion : LocalDateTime
    - ultimoAcceso : LocalDateTime
    --
    + autenticar(email: String, password: String): Boolean
    + cambiarPassword(actual: String, nueva: String): void
    + actualizarPerfil(datos: Object): void
    + getNombreCompleto(): String
  }

  class Cliente <<Usuarios>> {
    - dni : String
    - direccion : String
    - empresa : String
    --
    + solicitarConsulta(descripcion: String): Caso
    + verMisCasos(): List
    + agendarCita(fecha: LocalDateTime, abogadoId: Long): Cita
  }

  class Abogado <<Usuarios>> {
    - numeroColegiatura : String
    - especialidades : List
    - disponible : Boolean
    - tarifaHora : Decimal
    --
    + crearExpediente(casoId: Long): Expediente
    + registrarActuacion(expedienteId: Long, datos: Object): ActuacionProcesal
    + cerrarCaso(casoId: Long, observaciones: String): void
  }

  Usuario <|-- Cliente
  Usuario <|-- Abogado
}

package "Gestión Legal" {

  class Caso <<Legal>> {
    - id : Long
    - numeroCaso : String
    - titulo : String
    - descripcion : String
    - estado : EstadoCaso
    - fechaApertura : LocalDate
    - fechaCierre : LocalDate
    - prioridad : Integer
    --
    + abrir(): void
    + cerrar(observaciones: String): void
    + actualizarEstado(estado: EstadoCaso): void
    + asignarExpediente(expediente: Expediente): void
    + calcularCostoTotal(): Decimal
  }

  class Expediente <<Legal>> {
    - id : Long
    - numeroExpediente : String
    - juzgado : String
    - instancia : String
    - materiaLegal : String
    - fechaInicio : LocalDate
    --
    + agregarActuacion(actuacion: ActuacionProcesal): void
    + generarTimeline(): List
    + getUltimaActuacion(): ActuacionProcesal
  }

  class ActuacionProcesal <<Legal>> {
    - id : Long
    - tipo : TipoActuacion
    - descripcion : String
    - fechaActuacion : LocalDate
    - resultado : String
    --
    + registrar(): void
    + editar(datos: Object): void
  }

  class Cita <<Legal>> {
    - id : Long
    - fecha : LocalDateTime
    - lugar : String
    - estado : EstadoCita
    - notas : String
    --
    + confirmar(): void
    + cancelar(motivo: String): void
    + reprogramar(nuevaFecha: LocalDateTime): void
  }

  Caso "1" *-- "0..1" Expediente : contiene >
  Expediente "1" *-- "0..*" ActuacionProcesal : registra >
}

Cliente "1" --> "0..*" Caso : solicita >
Abogado "0..1" --> "0..*" Caso : gestiona >
Cliente "1" --> "0..*" Cita : agenda >
Abogado "1" --> "0..*" Cita : atiende >
Caso "0..1" --> "0..*" Cita : referida a >

package "Auditoría y Trazabilidad" {

  class Auditoria <<Auditoria>> {
    - id : Long
    - entidadAfectada : String
    - entidadId : Long
    - accion : AccionAuditoria
    - descripcion : String
    - valoresAnteriores : String
    - valoresNuevos : String
    - ipOrigen : String
    - fechaHora : LocalDateTime
    --
    + registrar(): void
    + obtenerHistorial(entidad: String, entidadId: Long): List
  }

}

Usuario "1" --> "0..*" Auditoria : genera >

note top of Usuario
  Clase abstracta base.
  Herencia SINGLE_TABLE.
end note

note as N1
  Composición: Si el Caso se elimina,
  el Expediente también.
end note

Caso .. N1
N1 .. Expediente

note bottom of Caso
  La relación con Documento se
  incorpora en la Versión 2.
end note

legend right
  Usuarios y Seguridad
  Gestión Legal
  Auditoría y Trazabilidad
  Enumeraciones
endlegend

@enduml
